{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copaw.dev/schemas/pipeline-spec.schema.json",
  "title": "CoPaw PipelineSpec",
  "type": "object",
  "required": [
    "spec_version",
    "pipeline"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "pipeline": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version",
        "domain",
        "steps"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "domain": {
          "type": "string",
          "enum": [
            "markdown-alignment",
            "classics-kg",
            "semantic-publishing",
            "generic"
          ]
        },
        "description": { "type": "string" },
        "owners": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "required"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "description": { "type": "string" }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "executor", "depends_on"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "executor": { "type": "string" },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              },
              "inputs_from": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              },
              "outputs": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              },
              "retry": {
                "type": "object",
                "properties": {
                  "max_attempts": { "type": "integer", "minimum": 1, "default": 1 },
                  "backoff_sec": { "type": "integer", "minimum": 0, "default": 0 }
                },
                "additionalProperties": false,
                "default": { "max_attempts": 1, "backoff_sec": 0 }
              },
              "quality_gates": {
                "type": "array",
                "items": { "type": "string" },
                "default": []
              }
            },
            "additionalProperties": false
          }
        },
        "publish_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["report", "index-page", "api", "bundle"]
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
